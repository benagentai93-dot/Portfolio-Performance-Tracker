# Firebase Web App config (Project settings → Your apps → SDK setup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Internal app namespace under Firestore (defaults to "portfolio-performance-tracker")
VITE_APP_ID=portfolio-performance-tracker

# Optional: pre-issued custom auth token (otherwise anonymous sign-in is used)
VITE_INITIAL_AUTH_TOKEN=

# Google AI Studio key for Gemini features (price auto-fill, AI advisor, image scan)
VITE_GEMINI_API_KEY=
